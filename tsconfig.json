{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],

    "skipLibCheck": true,
    "verbatimModuleSyntax": true,

    "isolatedModules": true
  },
  "exclude": ["scripts"]
}